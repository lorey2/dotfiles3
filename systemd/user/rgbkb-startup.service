[Unit]
Description=RGBKB RGB Keyboard Effect
After=graphical-session.target

[Service]
Type=oneshot
ExecStart=/home/lorey/.local/bin/rgbkb fireball FF69B4 --speed 4 --level 32
RemainAfterExit=yes
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/lorey

[Install]
WantedBy=default.target
